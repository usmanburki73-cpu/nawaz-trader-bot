NODE_ENV=development
PORT=5001
LOG_LEVEL=info

ALIBABA_API_KEY=your_alibaba_api_key
ALIBABA_API_SECRET=your_alibaba_api_secret
AMAZON_ACCESS_KEY=your_amazon_access_key
AMAZON_SECRET_KEY=your_amazon_secret_key
AMAZON_SELLER_ID=your_amazon_seller_id
AMAZON_REGION=us-east-1

BACKEND_URL=http://localhost:5000
BACKEND_API_TOKEN=your_backend_token

DATABASE_URL=postgresql://user:password@localhost:5432/nawaz_trader
REDIS_URL=redis://localhost:6379

SYNC_INTERVAL_MINUTES=60
ALIBABA_SEARCH_KEYWORDS=power tools,safety equipment,plumbing supplies
PRODUCT_MARKUP_PERCENT=25
AUTO_UPDATE_INVENTORY=true
AUTO_UPDATE_PRICES=true

LOG_FILE=logs/bot.log
LOG_ERROR_FILE=logs/errors.log

SLACK_WEBHOOK_URL=your_slack_webhook_url
ENABLE_SLACK_NOTIFICATIONS=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=admin@nawaztrader.com

USE_PUPPETEER_PROXY=false
PROXY_URL=http://proxy:port
HEADLESS_MODE=true